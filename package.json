    "README.md",
    "LICENSE"
  ],
  "bin": {
    "screenshot-cleanup": "./bin/screenshot-cleanup.js",
    "ssc": "./bin/screenshot-cleanup.js",
    "ssc-codex-hook": "./bin/ssc-codex-hook.js",
    "ssc-copilot-hook": "./bin/ssc-copilot-hook.js"
  },
  "scripts": {
